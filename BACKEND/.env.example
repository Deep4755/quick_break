# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (use MONGO_URL — this is what the app reads)
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Mapbox — get from https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your_mapbox_public_token_here
MAPBOX_PROFILE=driving

# TomTom (optional — only needed for seeding stations from TomTom API)
TOMTOM_API_KEY=your_tomtom_api_key_here

# CORS — only needed if frontend is on a different domain than backend
# In Hostinger single-app mode, leave this commented out
# CORS_ORIGIN=https://yourdomain.com

# Email / SMTP (optional — contact form saves to DB even without these)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password_here
# SUPPORT_EMAIL=support@quickbreak.uk
