# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
FRONTEND/node_modules/
BACKEND/node_modules/

# ── Environment files (NEVER commit real secrets) ─────────────────────────────
.env
.env.local
.env.*.local
BACKEND/.env
FRONTEND/.env

# These are SAFE to commit (no real secrets):
!FRONTEND/.env.production
!BACKEND/.env.example
!FRONTEND/.env.example

# ── Build output ──────────────────────────────────────────────────────────────
# FRONTEND/dist is committed to git so Hostinger can serve it without a build step
# Do NOT add FRONTEND/dist/ here
build/
coverage/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
