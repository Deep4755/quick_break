# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
FRONTEND/node_modules/
BACKEND/node_modules/

# ── Environment files (NEVER commit real secrets) ─────────────────────────────
.env
.env.local
.env.*.local
BACKEND/.env
FRONTEND/.env

# These are SAFE to commit (no real secrets):
!FRONTEND/.env.production
!BACKEND/.env.example
!FRONTEND/.env.example

# ── Build output ──────────────────────────────────────────────────────────────
# Keep FRONTEND/dist in git so Hostinger doesn't need to build it
# FRONTEND/dist/
dist/
build/
coverage/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
